module GoldyLox
  interface _StatementVisitor[R]
    def visit_block: (Statement::Block) -> R
    def visit_expression: (Statement::Expression) -> R
    def visit_function: (Statement::Function) -> R
    def visit_if: (Statement::If) -> R
    def visit_print: (Statement::Print) -> R
    def visit_return: (Statement::Return) -> void # actually never returns
    def visit_var: (Statement::Var) -> R
    def visit_while: (Statement::While) -> R
  end
end
